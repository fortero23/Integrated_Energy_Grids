    "\n",
    "fixed_OM_BESS_for_inverter = 0.03 #FOM\n",
    "capital_cost_BESS = annuity(lifetime_BESS, discount_rate) * BESS_total_cost_per_MW * (1 + fixed_OM_BESS_for_inverter)   # EUR/MW-year\n",
