    ")\n",
    "\n",
    "ax.fill_between(\n",
    "    hours, 0, np.maximum(summer_step, 0),\n",
    "    step=\"post\", color=\"purple\", alpha=0.22, hatch=\"\\\\\\\\\"\n",
